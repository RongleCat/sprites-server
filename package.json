{
  "name": "sprites-client",
  "version": "1.0.0",
  "type": "module",
  "description": "Claude Agent SDK proxy server for Sprites",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "type-check": "tsc --noEmit",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:dev": "pm2 start ecosystem.config.js --env development",
    "pm2:stop": "pm2 stop sprites-agent-server",
    "pm2:restart": "pm2 restart sprites-agent-server",
    "pm2:reload": "pm2 reload sprites-agent-server",
    "pm2:delete": "pm2 delete sprites-agent-server",
    "pm2:logs": "pm2 logs sprites-agent-server",
    "pm2:monit": "pm2 monit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "hono": "^4.6.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.2.2",
    "nanoid": "^5.0.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "bun-types": "^1.1.34"
  },
  "peerDependencies": {
    "typescript": "^5.7.2"
  }
}
